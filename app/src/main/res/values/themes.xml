<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Nabd" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/nabd_primary</item>
        <item name="colorOnPrimary">@color/nabd_on_primary</item>
        <item name="colorPrimaryContainer">@color/nabd_primary_container</item>
        <item name="colorSecondary">@color/nabd_secondary</item>
        <item name="colorOnSecondary">@color/nabd_on_secondary</item>
        <item name="colorError">@color/nabd_error</item>
        <item name="colorOnError">@color/nabd_on_error</item>
        <item name="colorSurfaceVariant">@color/nabd_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/nabd_on_surface_variant</item>
        <item name="android:colorBackground">@color/nabd_background</item>
        <item name="colorSurface">@color/nabd_surface</item>
        <item name="colorOnSurface">@color/nabd_on_surface</item>
        <item name="colorOutline">@color/nabd_outline</item>
        <item name="android:navigationBarColor">@color/nabd_surface</item>
        <item name="android:statusBarColor">@color/nabd_surface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="Theme.Nabd.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/nabd_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.Nabd</item>
    </style>
</resources>
