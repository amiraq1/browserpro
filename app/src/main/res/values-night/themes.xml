<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Nabd" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/nabd_primary_dark</item>
        <item name="colorOnPrimary">@color/nabd_on_primary_dark</item>
        <item name="colorPrimaryContainer">@color/nabd_primary_container_dark</item>
        <item name="colorSecondary">@color/nabd_secondary_dark</item>
        <item name="colorOnSecondary">@color/nabd_on_secondary_dark</item>
        <item name="colorError">@color/nabd_error_dark</item>
        <item name="colorOnError">@color/nabd_on_error_dark</item>
        <item name="colorSurfaceVariant">@color/nabd_surface_variant_dark</item>
        <item name="colorOnSurfaceVariant">@color/nabd_on_surface_variant_dark</item>
        <item name="android:colorBackground">@color/nabd_surface_dark</item>
        <item name="colorSurface">@color/nabd_surface_dark</item>
        <item name="colorOnSurface">@color/nabd_on_surface_dark</item>
        <item name="colorOutline">@color/nabd_outline_dark</item>
        <item name="android:navigationBarColor">@color/nabd_surface_dark</item>
        <item name="android:statusBarColor">@color/nabd_surface_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="Theme.Nabd.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/nabd_splash_bg_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.Nabd</item>
    </style>
</resources>
