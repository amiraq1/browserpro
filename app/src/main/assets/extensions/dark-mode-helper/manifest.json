{
  "manifest_version": 2,
  "name": "Dark Mode Helper",
  "version": "1.0",
  "description": "Simple helper to inject dark mode CSS.",
  "browser_specific_settings": {
    "gecko": {
      "id": "dark-mode-helper@nabd.example.com"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
