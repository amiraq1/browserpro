{
  "manifest_version": 2,
  "name": "Web Page Summarizer",
  "version": "1.0.0",
  "description": "Extracts readable page text and asks the Android host app for a short local mock summary.",
  "browser_specific_settings": {
    "gecko": {
      "id": "summarizer@example.com"
    }
  },
  "permissions": [
    "activeTab",
    "tabs",
    "nativeMessaging",
    "nativeMessagingFromContent",
    "geckoViewAddons"
  ],
  "browser_action": {
    "default_title": "Web Page Summarizer",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}
