{
  "manifest_version": 2,
  "name": "Web Page Summarizer",
  "version": "1.0.0",
  "description": "Summarizes the current web page using native Android code.",
  "browser_specific_settings": {
    "gecko": {
      "id": "summarizer@example.com"
    }
  },
  "permissions": [
    "activeTab",
    "tabs",
    "nativeMessaging",
    "nativeMessagingFromContent",
    "geckoViewAddons"
  ],
  "browser_action": {
    "default_title": "Summarize Page",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
