{
  "manifest_version": 2,
  "name": "BrowserPro Agent Bridge",
  "version": "1.0.0",
  "description": "Safe, limited bridge for local AI agent to inspect and control the active tab.",
  "browser_specific_settings": {
    "gecko": {
      "id": "agent-bridge@browserpro.local"
    }
  },
  "permissions": [
    "nativeMessaging",
    "tabs",
    "activeTab"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
